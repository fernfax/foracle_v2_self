# Mobile env vars. Copy to mobile/.env.local and fill in values.
# Variables prefixed with EXPO_PUBLIC_ are bundled into the app at build time.

# Clerk Expo publishable key (NOT the secret key). Find in Clerk dashboard:
# https://dashboard.clerk.com → API Keys → Publishable key
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Where the mobile app talks to the v1 API.
#   - iOS Simulator: http://localhost:3000 works.
#   - Physical device on the same LAN: use your dev machine's LAN IP,
#     e.g. http://192.168.1.42:3000  (run `ipconfig getifaddr en0` to find it).
#   - TestFlight / prod: https://your-render-url.onrender.com
EXPO_PUBLIC_API_URL=http://localhost:3000
