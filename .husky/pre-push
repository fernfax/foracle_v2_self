remote="$1"
url="$2"

# Husky invokes hooks with `sh -e`, so any non-zero status outside a conditional
# aborts the script. Use `if ! cmd` for explicit failure handling, and `|| true`
# inside cleanup traps so killed-process exit codes (143) don't leak through.

pushing_main=0
while read local_ref local_oid remote_ref remote_oid; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    pushing_main=1
  fi
done

if [ "$pushing_main" -eq 0 ]; then
  exit 0
fi

if [ -n "$SKIP_PREPUSH" ]; then
  echo "pre-push: SKIP_PREPUSH set, skipping all checks."
  exit 0
fi

# 1) Production build — Render runs the same on deploy.
if [ -z "$SKIP_BUILD" ]; then
  echo "pre-push: pushing to main — running production build..."
  if ! npm run build; then
    echo ""
    echo "pre-push: build failed. Push aborted."
    echo "  - Fix the build error, or set SKIP_BUILD=1 to bypass (NOT recommended — main auto-deploys)."
    exit 1
  fi
  echo "pre-push: build passed."
else
  echo "pre-push: SKIP_BUILD set, skipping build."
fi

# 2) E2E smoke against the production build on a separate port.
if [ -z "$SKIP_E2E" ]; then
  SMOKE_PORT="${SMOKE_PORT:-3100}"
  SERVER_LOG="$(mktemp -t foracle-prepush-server.XXXXXX.log)"
  echo "pre-push: starting next start on :$SMOKE_PORT for smoke tests..."
  npx next start -p "$SMOKE_PORT" > "$SERVER_LOG" 2>&1 &
  SERVER_PID=$!
  trap 'kill $SERVER_PID 2>/dev/null || true; wait $SERVER_PID 2>/dev/null || true; rm -f "$SERVER_LOG" 2>/dev/null || true' EXIT INT TERM

  # Wait up to 30s for the server to come up.
  i=0
  while [ "$i" -lt 30 ]; do
    if curl -fs --max-time 1 "http://localhost:$SMOKE_PORT/" > /dev/null 2>&1; then
      break
    fi
    sleep 1
    i=$((i + 1))
  done
  if ! curl -fs --max-time 2 "http://localhost:$SMOKE_PORT/" > /dev/null 2>&1; then
    echo ""
    echo "pre-push: next start did not come up on :$SMOKE_PORT in 30s. Push aborted."
    echo "  - Server log:"
    tail -20 "$SERVER_LOG"
    exit 1
  fi

  echo "pre-push: running smoke tests against http://localhost:$SMOKE_PORT ..."
  if ! PLAYWRIGHT_BASE_URL="http://localhost:$SMOKE_PORT" npm run test:e2e; then
    echo ""
    echo "pre-push: smoke tests failed. Push aborted."
    echo "  - Server log: $SERVER_LOG"
    echo "  - Fix the failing test, or set SKIP_E2E=1 to bypass."
    exit 1
  fi
  echo "pre-push: smoke tests passed."
else
  echo "pre-push: SKIP_E2E set, skipping smoke tests."
fi

exit 0
