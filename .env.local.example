# Database
DATABASE_URL="postgresql://user:password@localhost:5432/foracle"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Absolute origin used by family-invitations server action when building the
# Clerk invitation redirectUrl. Must be set per environment.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (for AI Assistant)
OPENAI_API_KEY=your_openai_api_key

# Vector Search Embeddings (choose one)
# Voyage AI (recommended) - https://voyageai.com
VOYAGE_API_KEY=your_voyage_api_key
# OR use OpenAI embeddings (uses OPENAI_API_KEY above)

# Platform admin allowlist (comma-separated verified emails). Anyone whose Clerk
# primary email matches gets cross-tenant access to /admin (feature-flag control
# for every household). Leave empty to disable the admin portal entirely.
FORACLE_SUPERADMIN_EMAILS=
