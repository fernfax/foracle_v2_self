# Deployment environment — one of: development | staging | production
NEXT_PUBLIC_DEPLOYMENT_ENVIRONMENT=development

# Hard WIP lock — "true" redirects every route to /coming-soon (see src/proxy.ts).
# Set per instance, independent of the env above: foracle.io = true to stay
# sealed; demo.foracle.io and local leave it false/unset so the app is usable.
NEXT_PUBLIC_SITE_LOCKED=false

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/foracle"

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_WEBHOOK_SECRET=your_clerk_webhook_secret
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Absolute origin used by family-invitations server action when building the
# Clerk invitation redirectUrl. Must be set per environment.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (for AI Assistant + embeddings fallback)
OPENAI_API_KEY=your_openai_api_key

# AI Assistant feature flag. The endpoint is enabled ONLY when this is "true" —
# in every environment, including local dev. Set deliberately per environment.
ENABLE_AI_ASSISTANT=true

# Vector Search Embeddings (choose one)
# Voyage AI (recommended) - https://voyageai.com
VOYAGE_API_KEY=your_voyage_api_key
# OR use OpenAI embeddings (uses OPENAI_API_KEY above)
